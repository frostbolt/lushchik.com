{
	"name": "lushchik-com",
	"version": "1.0.0",
	"description": "A blog built with Eleventy",
	"type": "module",
	"scripts": {
		"build": "npx @11ty/eleventy",
		"build-nocolor": "cross-env NODE_DISABLE_COLORS=1 npx @11ty/eleventy",
		"build-ghpages": "npx @11ty/eleventy",
		"start": "npx @11ty/eleventy --serve --quiet",
		"start-ghpages": "npx @11ty/eleventy --pathprefix=/11ty-test/ --serve --quiet",
		"debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
		"debugstart": "cross-env DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
		"benchmark": "cross-env DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
		"optimize:images": "node scripts/optimize-blog-images.js"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/frostbolt/lushchik.com.git"
	},
	"author": {
		"name": "Sergei Lushchik",
		"url": "https://lushchik.com/"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"homepage": "https://lushchik.com/",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.5",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"cross-env": "^10.1.0",
		"luxon": "^3.7.2",
		"prismjs": "^1.30.0",
		"zod": "^4.3.6",
		"zod-validation-error": "^5.0.0"
	},
	"dependencies": {
		"@resvg/resvg-js": "^2.6.2",
		"@zachleat/heading-anchors": "^1.0.5",
		"satori": "^0.26.0",
		"sharp": "^0.34.5"
	}
}
